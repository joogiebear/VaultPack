# ============================================
#           VaultPack - .gitignore
# ============================================

# Gradle
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# Ignore Gradle GUI config
gradle-app.setting

# Cache of project
.gradletasknamecache

# Eclipse Gradle plugin generated files
# https://github.com/eclipse/buildship/blob/master/docs/user/Installation.md#locations
.project
.classpath
.settings/
bin/

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/
!**/src/main/**/out/
!**/src/test/**/out/

# VS Code
.vscode/

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# Java / Kotlin
*.class
*.log
*.ctxt
.mtj.tmp/
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
hs_err_pid*
replay_pid*

# Virtual machine crash logs
# http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*

# Package Files (keep gradle wrapper)
!gradle-wrapper.jar

# Test server directories
test-server/
server/
run/
minecraft/

# Plugin output
*.jar
!libs/*.jar
!gradle/wrapper/gradle-wrapper.jar

# Player data (for testing)
playerdata/
plugins/VaultPack/data/
plugins/VaultPack/playerdata/

# Logs
logs/
*.log

# Temp files
*.tmp
*.temp
*.swp
*.swo
*~.nib

# Backup files
*.bak
*.backup
*~

# Config overrides for local testing
config-local.yml
test-config.yml

# Maven (if used)
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# Node (if using any JS/Node tools)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Custom ignores for VaultPack
# Uncomment if you want to ignore built jars
# build/libs/*.jar

# Keep example configs
!src/main/resources/*.yml
!src/main/resources/menus/*.yml

# Local development folders (keep out of repo)
.claude/
Aurora/
GitBook/

# Analysis and documentation files (local only)
ANALYSIS_README.md
AURORA_COMPARISON.md
AURORA_MIGRATION_GUIDE.md
FOLIA_COMPATIBILITY_ANALYSIS.md
FOLIA_CRITICAL_ISSUES_SUMMARY.md
FOLIA_QUICK_REFERENCE.txt
TESTING_CHECKLIST.md
*_ANALYSIS.md
*_SUMMARY.md
*_GUIDE.md
